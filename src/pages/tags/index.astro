---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getCollection } from 'astro:content';

// 1. 모든 문서 가져오기
const docs = await getCollection('docs');

// 2. 태그 및 개수 집계
const tagCounts: Record<string, number> = {};
docs.forEach(doc => {
  const tags = doc.data.tags;
  if (Array.isArray(tags)) {
    tags.forEach(tag => {
      const trimmedTag = tag.trim();
      if (trimmedTag) {
        tagCounts[trimmedTag] = (tagCounts[trimmedTag] || 0) + 1;
      }
    });
  }
});

// 3. 태그 알파벳 정렬
const sortedTags = Object.keys(tagCounts).sort((a, b) => a.localeCompare(b));
---

<StarlightPage frontmatter={{ title: '태그 목록', description: '개발 노트에 등록된 모든 태그 목록입니다.', template: 'splash' }}>
  <div class="tag-container">
    {sortedTags.length === 0 ? (
      <p class="no-tags">등록된 태그가 아직 없습니다.</p>
    ) : (
      <div class="tag-grid">
        {sortedTags.map(tag => (
          <a href={`/tags/${tag.toLowerCase()}`} class="tag-card">
            <span class="tag-name">#{tag}</span>
            <span class="tag-count">{tagCounts[tag]}개의 문서</span>
          </a>
        ))}
      </div>
    )}
  </div>
</StarlightPage>

<style>
  .tag-container {
    margin-top: 1rem;
  }
  .no-tags {
    color: var(--sl-color-gray-3);
    font-size: 1.1rem;
  }
  .tag-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1.25rem;
    margin-top: 1.5rem;
  }
  .tag-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.25rem;
    background-color: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.5rem;
    text-decoration: none;
    color: var(--sl-color-text);
    transition: border-color 0.2s, background-color 0.2s, transform 0.2s;
  }
  .tag-card:hover {
    border-color: var(--sl-color-text-accent);
    background-color: var(--sl-color-bg-inline-code);
    transform: translateY(-2px);
  }
  .tag-name {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--sl-color-text-accent);
  }
  .tag-count {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: var(--sl-color-gray-3);
  }
</style>
