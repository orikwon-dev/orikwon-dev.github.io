---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  
  // 태그 목록 수집 (소문자 태그 -> 원본 태그 매핑)
  const tagsMap = new Map<string, string>();
  
  docs.forEach(doc => {
    const tags = doc.data.tags;
    if (Array.isArray(tags)) {
      tags.forEach(tag => {
        const trimmedTag = tag.trim();
        if (trimmedTag) {
          tagsMap.set(trimmedTag.toLowerCase(), trimmedTag);
        }
      });
    }
  });

  return Array.from(tagsMap.entries()).map(([lowercaseTag, originalTag]) => {
    return {
      params: { tag: lowercaseTag },
      props: { originalTag }
    };
  });
}

const { tag } = Astro.params;
const { originalTag } = Astro.props;

// 해당 태그가 달린 문서들 필터링
const docs = await getCollection('docs');
const filteredDocs = docs.filter(doc => {
  const tags = doc.data.tags;
  return Array.isArray(tags) && tags.some(t => t.trim().toLowerCase() === tag);
});

// 문서 제목 순으로 정렬
filteredDocs.sort((a, b) => a.data.title.localeCompare(b.data.title));

// doc.id를 활용해 정확한 Starlight URL 빌드하는 헬퍼 함수
function getDocUrl(docId: string) {
  // 확장자 제거 (.md, .mdx)
  let cleanId = docId.replace(/\.mdx?$/, '');
  
  // index.md인 경우 빈 문자열 처리, 하위 index.md인 경우 폴더 경로만 유지
  if (cleanId === 'index') {
    cleanId = '';
  } else if (cleanId.endsWith('/index')) {
    cleanId = cleanId.slice(0, -6);
  }
  
  // URL은 소문자로 라우팅됨
  return `/${cleanId.toLowerCase()}`;
}
---

<StarlightPage frontmatter={{ title: `#${originalTag} 문서 목록`, description: `#${originalTag} 태그가 달린 개발 노트 문서 목록입니다.`, template: 'splash' }}>
  <div class="back-link-container">
    <a href="/tags" class="back-link">&larr; 전체 태그 목록으로 돌아가기</a>
  </div>
  
  <div class="docs-container">
    {filteredDocs.length === 0 ? (
      <p class="no-docs">해당 태그가 지정된 문서가 없습니다.</p>
    ) : (
      <div class="docs-list">
        {filteredDocs.map(doc => (
          <a href={getDocUrl(doc.id)} class="doc-item">
            <span class="doc-title">{doc.data.title}</span>
            {doc.data.description && <span class="doc-desc">{doc.data.description}</span>}
          </a>
        ))}
      </div>
    )}
  </div>
</StarlightPage>

<style>
  .back-link-container {
    margin-bottom: 1.5rem;
  }
  .back-link {
    font-size: 0.95rem;
    color: var(--sl-color-text-accent);
    text-decoration: none;
  }
  .back-link:hover {
    text-decoration: underline;
  }
  .docs-container {
    margin-top: 1rem;
  }
  .no-docs {
    color: var(--sl-color-gray-3);
  }
  .docs-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .doc-item {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    background-color: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.5rem;
    text-decoration: none;
    color: var(--sl-color-text);
    transition: border-color 0.2s, background-color 0.2s, transform 0.2s;
  }
  .doc-item:hover {
    border-color: var(--sl-color-text-accent);
    background-color: var(--sl-color-bg-inline-code);
    transform: translateY(-1px);
  }
  .doc-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--sl-color-text-accent);
  }
  .doc-desc {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: var(--sl-color-gray-3);
  }
</style>
